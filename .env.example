# Application name shown in service metadata and health responses.
PYTHON_CLAW_APP_NAME=python-claw-gateway

# Main database connection string used by the application.
PYTHON_CLAW_DATABASE_URL=postgresql+psycopg://openassistant:openassistant@localhost:5432/openassistant

# Number of days to retain inbound dedupe records.
PYTHON_CLAW_DEDUPE_RETENTION_DAYS=30

# Number of seconds before a claimed dedupe record is treated as stale.
PYTHON_CLAW_DEDUPE_STALE_AFTER_SECONDS=300

# Default page size for session message history.
PYTHON_CLAW_MESSAGES_PAGE_DEFAULT_LIMIT=50

# Maximum page size for session message history.
PYTHON_CLAW_MESSAGES_PAGE_MAX_LIMIT=100

# Default agent id used when no other agent is resolved.
PYTHON_CLAW_DEFAULT_AGENT_ID=default-agent

# JSON array of policy-profile definitions keyed by stable profile key; each profile controls per-agent policy flags such as remote execution, denied capabilities, and delegation enablement.
PYTHON_CLAW_POLICY_PROFILES=[{"key":"default","remote_execution_enabled":false,"denied_capability_names":[],"delegation_enabled":false,"max_delegation_depth":0,"allowed_child_agent_ids":[],"max_active_delegations_per_run":null,"max_active_delegations_per_session":null}]

# JSON array of tool-profile definitions keyed by stable profile key; each profile defines the capability allowlist that can be exposed for an agent at runtime.
PYTHON_CLAW_TOOL_PROFILES=[{"key":"default","allowed_capability_names":["echo_text","remote_exec","send_message"]}]

# JSON array of legacy agent override mappings used during bootstrap or migration to attach historical agent ids to specific model, policy, and tool profiles.
PYTHON_CLAW_HISTORICAL_AGENT_PROFILE_OVERRIDES=[]

# Number of transcript messages kept in immediate runtime context before continuity logic.
PYTHON_CLAW_RUNTIME_TRANSCRIPT_CONTEXT_LIMIT=20

# Runtime mode that selects rule-based or provider-backed turn execution.
PYTHON_CLAW_RUNTIME_MODE=rule_based

# Flag that enables delivery-side streaming for eligible assistant text responses.
PYTHON_CLAW_RUNTIME_STREAMING_ENABLED=true

# Maximum text characters emitted in each backend-owned streaming delta chunk.
PYTHON_CLAW_RUNTIME_STREAMING_CHUNK_CHARS=24

# Flag that enables the authenticated webchat SSE replay endpoint.
PYTHON_CLAW_WEBCHAT_SSE_ENABLED=true

# Maximum number of durable SSE events returned in one webchat replay page.
PYTHON_CLAW_WEBCHAT_SSE_REPLAY_LIMIT=100

# Provider name used when runtime mode is provider.
PYTHON_CLAW_LLM_PROVIDER=openai

# API key used for provider-backed model calls.
PYTHON_CLAW_LLM_API_KEY=

# Optional base URL override for provider-compatible endpoints.
PYTHON_CLAW_LLM_BASE_URL=

# Model name used for provider-backed turns.
PYTHON_CLAW_LLM_MODEL=gpt-4o-mini

# Timeout in seconds for one provider request.
PYTHON_CLAW_LLM_TIMEOUT_SECONDS=30

# Maximum provider-level retries within one worker attempt.
PYTHON_CLAW_LLM_MAX_RETRIES=1

# Sampling temperature used for provider-backed responses.
PYTHON_CLAW_LLM_TEMPERATURE=0.2

# Maximum output tokens requested from the provider.
PYTHON_CLAW_LLM_MAX_OUTPUT_TOKENS=512

# Tool call mode exposed to the provider runtime.
PYTHON_CLAW_LLM_TOOL_CALL_MODE=auto

# Maximum number of tool requests allowed in one turn.
PYTHON_CLAW_LLM_MAX_TOOL_REQUESTS_PER_TURN=4

# Flag that disables all tool exposure even when tools are configured.
PYTHON_CLAW_LLM_DISABLE_TOOLS=false

# Lease duration for claimed execution runs.
PYTHON_CLAW_EXECUTION_RUN_LEASE_SECONDS=60

# Maximum execution attempts allowed for one run.
PYTHON_CLAW_EXECUTION_RUN_MAX_ATTEMPTS=5

# Base retry backoff for failed execution runs.
PYTHON_CLAW_EXECUTION_RUN_BACKOFF_SECONDS=5

# Maximum retry backoff for failed execution runs.
PYTHON_CLAW_EXECUTION_RUN_BACKOFF_MAX_SECONDS=300

# Global concurrency limit for active execution runs.
PYTHON_CLAW_EXECUTION_RUN_GLOBAL_CONCURRENCY=4

# Default page size for session run listings.
PYTHON_CLAW_SESSION_RUNS_PAGE_DEFAULT_LIMIT=20

# Maximum page size for session run listings.
PYTHON_CLAW_SESSION_RUNS_PAGE_MAX_LIMIT=50

# Maximum attachment metadata size accepted at inbound time.
PYTHON_CLAW_INBOUND_ATTACHMENT_MAX_METADATA_CHARS=2000

# Root directory used for normalized media storage.
PYTHON_CLAW_MEDIA_STORAGE_ROOT=.claw-media

# Logical media bucket name stored with normalized attachments.
PYTHON_CLAW_MEDIA_STORAGE_BUCKET=local-media

# Intended retention window for normalized media.
PYTHON_CLAW_MEDIA_RETENTION_DAYS=30

# Allowed URL schemes for inbound attachment sources.
PYTHON_CLAW_MEDIA_ALLOWED_SCHEMES=file,https

# Allowed MIME type prefixes for accepted attachments.
PYTHON_CLAW_MEDIA_ALLOWED_MIME_PREFIXES=image/,audio/,text/,application/pdf

# Maximum allowed attachment size in bytes.
PYTHON_CLAW_MEDIA_MAX_BYTES=5242880

# Flag that enables retrieval during context assembly.
PYTHON_CLAW_RETRIEVAL_ENABLED=true

# Strategy id used for retrieval selection and indexing.
PYTHON_CLAW_RETRIEVAL_STRATEGY_ID=lexical-v1

# Total retrieval items allowed into one assembled turn.
PYTHON_CLAW_RETRIEVAL_TOTAL_ITEMS=4

# Maximum retrieval items sourced from durable memories.
PYTHON_CLAW_RETRIEVAL_MEMORY_ITEMS=2

# Maximum retrieval items sourced from attachment-derived content.
PYTHON_CLAW_RETRIEVAL_ATTACHMENT_ITEMS=2

# Maximum retrieval items sourced from other additive records.
PYTHON_CLAW_RETRIEVAL_OTHER_ITEMS=2

# Chunk size used when building retrieval records.
PYTHON_CLAW_RETRIEVAL_CHUNK_CHARS=280

# Minimum retrieval score required for inclusion.
PYTHON_CLAW_RETRIEVAL_MIN_SCORE=1.0

# Flag that enables durable memory extraction and use.
PYTHON_CLAW_MEMORY_ENABLED=true

# Strategy id used for durable memory derivation.
PYTHON_CLAW_MEMORY_STRATEGY_ID=memory-v1

# Flag that enables attachment-content extraction.
PYTHON_CLAW_ATTACHMENT_EXTRACTION_ENABLED=true

# Strategy id used for attachment-content extraction.
PYTHON_CLAW_ATTACHMENT_EXTRACTION_STRATEGY_ID=attachment-v1

# Flag that enables bounded same-run attachment fast-path extraction.
PYTHON_CLAW_ATTACHMENT_SAME_RUN_FAST_PATH_ENABLED=true

# Maximum bytes eligible for same-run attachment fast-path extraction.
PYTHON_CLAW_ATTACHMENT_SAME_RUN_MAX_BYTES=262144

# Maximum PDF pages eligible for same-run fast-path extraction.
PYTHON_CLAW_ATTACHMENT_SAME_RUN_PDF_PAGE_LIMIT=5

# Timeout in seconds for same-run attachment fast-path extraction.
PYTHON_CLAW_ATTACHMENT_SAME_RUN_TIMEOUT_SECONDS=2

# Maximum recent transcript turns packaged into a child delegation request.
PYTHON_CLAW_DELEGATION_PACKAGE_TRANSCRIPT_TURNS=6

# Maximum retrieval or memory items packaged into a child delegation request.
PYTHON_CLAW_DELEGATION_PACKAGE_RETRIEVAL_ITEMS=4

# Maximum attachment excerpts packaged into a child delegation request.
PYTHON_CLAW_DELEGATION_PACKAGE_ATTACHMENT_ITEMS=2

# Maximum serialized character budget for one child delegation package.
PYTHON_CLAW_DELEGATION_PACKAGE_MAX_CHARS=4000

# Flag that enables remote execution capability routing.
PYTHON_CLAW_REMOTE_EXECUTION_ENABLED=false

# Signing key id used for node-runner requests.
PYTHON_CLAW_NODE_RUNNER_SIGNING_KEY_ID=local-dev

# Shared signing secret used for node-runner request signatures.
PYTHON_CLAW_NODE_RUNNER_SIGNING_SECRET=local-dev-secret

# Maximum request age accepted by the node-runner.
PYTHON_CLAW_NODE_RUNNER_REQUEST_TTL_SECONDS=30

# Hard timeout ceiling enforced for node execution requests.
PYTHON_CLAW_NODE_RUNNER_TIMEOUT_CEILING_SECONDS=30

# Flag that allows sandbox mode off for supported profiles.
PYTHON_CLAW_NODE_RUNNER_ALLOW_OFF_MODE=false

# Allowlisted executables permitted for node-runner execution.
PYTHON_CLAW_NODE_RUNNER_ALLOWED_EXECUTABLES=/bin/echo,/usr/bin/env

# Root directory used for sandbox workspace resolution.
PYTHON_CLAW_SANDBOX_WORKSPACE_ROOT=.claw-sandboxes

# Shared sandbox profile key used when shared mode is selected.
PYTHON_CLAW_SANDBOX_SHARED_BASE_KEY=shared-default

# Flag that enables JSON-formatted structured logs.
PYTHON_CLAW_OBSERVABILITY_JSON_LOGS=true

# Flag that allows bounded content previews in logs and diagnostics.
PYTHON_CLAW_OBSERVABILITY_LOG_CONTENT_PREVIEW=false

# Maximum characters included in bounded log or diagnostics previews.
PYTHON_CLAW_OBSERVABILITY_LOG_CONTENT_PREVIEW_CHARS=160

# Flag that enables diagnostics APIs and services.
PYTHON_CLAW_DIAGNOSTICS_ENABLED=true

# Default page size for diagnostics endpoints.
PYTHON_CLAW_DIAGNOSTICS_PAGE_DEFAULT_LIMIT=20

# Maximum page size for diagnostics endpoints.
PYTHON_CLAW_DIAGNOSTICS_PAGE_MAX_LIMIT=50

# Bearer token used for authenticated diagnostics access.
PYTHON_CLAW_DIAGNOSTICS_ADMIN_BEARER_TOKEN=change-me

# Internal service token accepted by diagnostics and readiness routes.
PYTHON_CLAW_DIAGNOSTICS_INTERNAL_SERVICE_TOKEN=change-me-internal

# Flag that requires auth on the readiness endpoint.
PYTHON_CLAW_HEALTH_READY_REQUIRES_AUTH=true

# Flag that enables metrics export surfaces.
PYTHON_CLAW_OBSERVABILITY_METRICS_ENABLED=false

# Path where metrics are exposed when enabled.
PYTHON_CLAW_OBSERVABILITY_METRICS_PATH=/metrics

# Flag that enables tracing instrumentation when configured.
PYTHON_CLAW_OBSERVABILITY_TRACING_ENABLED=false

# Age threshold in seconds before a claimed or running execution run is considered stale.
PYTHON_CLAW_EXECUTION_RUN_STALE_AFTER_SECONDS=300

# Age threshold in seconds before a running outbox job is considered stale.
PYTHON_CLAW_OUTBOX_JOB_STALE_AFTER_SECONDS=300

# Age threshold in seconds before a scheduled fire is considered stale.
PYTHON_CLAW_SCHEDULED_JOB_FIRE_STALE_AFTER_SECONDS=300

# Age threshold in seconds before a non-terminal delivery is considered stale.
PYTHON_CLAW_OUTBOUND_DELIVERY_STALE_AFTER_SECONDS=300

# Age threshold in seconds before a node execution is considered stale.
PYTHON_CLAW_NODE_EXECUTION_STALE_AFTER_SECONDS=300

# Age threshold in seconds before an attachment workflow is considered stale.
PYTHON_CLAW_ATTACHMENT_STALE_AFTER_SECONDS=300

# Typed channel-account registry used for Slack, Telegram, and webchat transport resolution.
PYTHON_CLAW_CHANNEL_ACCOUNTS=[{"channel_account_id":"acct","channel_kind":"slack","mode":"fake"},{"channel_account_id":"acct","channel_kind":"telegram","mode":"fake"},{"channel_account_id":"acct","channel_kind":"webchat","mode":"fake"},{"channel_account_id":"acct-1","channel_kind":"slack","mode":"fake"},{"channel_account_id":"acct-1","channel_kind":"telegram","mode":"fake"},{"channel_account_id":"acct-1","channel_kind":"webchat","mode":"fake"}]

# Local Docker Compose PostgreSQL database name.
PYTHON_CLAW_POSTGRES_DB=openassistant

# Local Docker Compose PostgreSQL username.
PYTHON_CLAW_POSTGRES_USER=openassistant

# Local Docker Compose PostgreSQL password.
PYTHON_CLAW_POSTGRES_PASSWORD=openassistant

# Local Docker Compose PostgreSQL port mapping.
PYTHON_CLAW_POSTGRES_PORT=5432

# Local Docker Compose Redis port mapping.
PYTHON_CLAW_REDIS_PORT=6379
